{
    "custom/updates": {
        "format": "{icon} {}",
        "hide-empty-text": true,
        "format-icons": {
            "default": "󰚰",
            "empty": " "
        },
        "return-type": "json",
        "exec": "~/.config/waybar/scripts/updates.sh",
        "interval": 1800,
        "on-click": "kitty bash -c 'yay -Syu; flatpak update; echo Done - Press any key to exit; read -n1'",
        "escape": true
    }
}